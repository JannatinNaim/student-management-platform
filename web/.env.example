# Leave NEXT_PUBLIC_API_URL blank to auto-detect the API on the same host the
# site is opened from (localhost, clamshell.local, a LAN IP, ...). Set it
# explicitly only when the API lives on a different domain (e.g. production).
#
# Production (frontend on Vercel, API on Render) — set the full API origin:
#   NEXT_PUBLIC_API_URL=https://smartnotes-api.onrender.com
NEXT_PUBLIC_API_URL=
# Port the API listens on, used by the auto-detection above. Defaults to 4000.
NEXT_PUBLIC_API_PORT=4000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# Your public site origin, used for SEO metadata, e.g. https://smartnotes.vercel.app
NEXT_PUBLIC_SITE_URL=
