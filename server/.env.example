# --- Core ---
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed browser origins (CORS). In production set this
# to your deployed web origin(s), e.g. https://smartnotes.vercel.app
CLIENT_URL=http://localhost:3000

# --- Database (PostgreSQL) ---
# Local development points at the Postgres started by docker-compose.yml
# (`docker compose up -d`). In production use your managed Postgres connection
# string (e.g. Neon, Supabase, Render Postgres) — prefer the pooled URL.
DATABASE_URL=postgresql://smartnotes:smartnotes@localhost:5434/smartnotes?schema=public

# --- Auth ---
JWT_ACCESS_SECRET=change-me-access-secret-min-32-characters!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-characters!
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

# --- Google OAuth (optional - leave blank to disable) ---
GOOGLE_CLIENT_ID=

# --- File storage ---
# MAX_FILE_SIZE_MB caps every upload.
MAX_FILE_SIZE_MB=15
#
# STORAGE_DRIVER selects the backend:
#   local  -> filesystem under server/uploads, served from /uploads (default in dev)
#   s3     -> any S3-compatible object store (Cloudflare R2, AWS S3, MinIO)
# It defaults to "s3" automatically when S3_BUCKET is set, otherwise "local".
STORAGE_DRIVER=local
#
# --- S3 / Cloudflare R2 (only needed when STORAGE_DRIVER=s3) ---
# Cloudflare R2 example:
#   S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
#   S3_REGION=auto
#   S3_BUCKET=smartnotes
#   S3_ACCESS_KEY_ID=<r2 access key id>
#   S3_SECRET_ACCESS_KEY=<r2 secret access key>
#   S3_PUBLIC_URL=https://<your-r2-public-bucket-or-custom-domain>
#   S3_FORCE_PATH_STYLE=false
#
# Local MinIO example (docker compose --profile s3 up -d):
#   S3_ENDPOINT=http://localhost:9100
#   S3_REGION=auto
#   S3_BUCKET=smartnotes
#   S3_ACCESS_KEY_ID=minioadmin
#   S3_SECRET_ACCESS_KEY=minioadmin
#   S3_PUBLIC_URL=http://localhost:9100/smartnotes
#   S3_FORCE_PATH_STYLE=true
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=
S3_FORCE_PATH_STYLE=false

# --- Email (optional - falls back to console logging) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Smart Notes <no-reply@smartnotes.app>"
