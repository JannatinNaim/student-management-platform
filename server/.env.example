# --- Core ---
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:3000

# --- Database (SQLite - no external DB server required) ---
DATABASE_URL=file:./dev.db

# --- Auth ---
JWT_ACCESS_SECRET=change-me-access-secret-min-32-characters!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-characters!
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

# --- Google OAuth (optional - leave blank to disable) ---
GOOGLE_CLIENT_ID=

# --- File storage (local filesystem, served from /uploads) ---
MAX_FILE_SIZE_MB=15

# --- Email (optional - falls back to console logging) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Smart Notes <no-reply@smartnotes.app>"
